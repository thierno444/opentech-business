# Créez ou vérifiez le .gitignore
cat > .gitignore << 'EOF'
# Dependencies
node_modules/
.pnp/
.pnp.js

# Testing
coverage/

# Production
dist/
build/
.next/
out/

# Environment files
.env
.env.local
.env.production

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Cache
.cache/
.parcel-cache/
.vite/

# MongoDB
mongodb-data/

# Uploads
uploads/

# Temp files
tmp/
temp/

# Misc
*.pid
*.seed
*.pid.lock
EOFuploads/
uploads_backup/
